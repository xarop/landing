---
import type { Translation } from '../i18n/types';
interface Props { t: Translation }
const { t } = Astro.props;
---
<section id="serveis" class="services">
  <div class="wrap">
    <div class="sec-head reveal">
      <div>
        <span class="sec-head__tag">{t.services.tag}</span>
        <h2>{t.services.title}</h2>
      </div>
      <p class="sec-head__lead">{t.services.lead}</p>
    </div>

    <div class="services__grid">
      {t.services.items.map((item) => (
        <article class="service reveal">
          <div class="service__num">{item.num}</div>
          <div>
            <h3>{item.title}</h3>
            <p class="service__desc">{item.desc}</p>
            <div class="service__tags">
              {item.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
