---
import type { Translation } from '../i18n/types';
import ContactModal from './ContactModal.astro';
interface Props { t: Translation }
const { t } = Astro.props;
---
<section id="contacte" class="cta">
  <div class="wrap">
    <h2 class="cta__big reveal">
      <Fragment set:html={t.cta.questionHtml} />
      <a href="mailto:hola@xarop.com">hola@xarop.com</a>
    </h2>
    <p class="cta__sub reveal">{t.cta.sub}</p>
    <div class="cta__row reveal">
      <button type="button" class="btn btn--primary" id="open-contact-modal">{t.cta.primary} <span class="arrow" aria-hidden="true">→</span></button>
      <a href="#" class="btn btn--ghost">{t.cta.secondary}</a>
    </div>
    <ContactModal t={t} />
  </div>
</section>
