---
import type { Translation } from '../i18n/types';
interface Props { t: Translation }
const { t } = Astro.props;
---
<div id="contact-modal" class="modal" aria-hidden="true" tabindex="-1">
  <div class="modal__backdrop" tabindex="-1"></div>
  <div class="modal__content" role="dialog" aria-modal="true" aria-labelledby="contact-modal-title">
    <button class="modal__close" type="button" aria-label="Close">×</button>
    <h2 id="contact-modal-title">{t.contact?.title ?? 'Contacta'}</h2>
    <form class="contact-form" id="contact-form" method="POST" action="/contact.php" autocomplete="on">
      <label>
        <span>{t.contact?.name ?? 'Nom'}</span>
        <input type="text" name="name" required autocomplete="name" />
      </label>
      <label>
        <span>{t.contact?.email ?? 'Email'}</span>
        <input type="email" name="email" required autocomplete="email" />
      </label>
      <label>
        <span>{t.contact?.message ?? 'Missatge'}</span>
        <textarea name="message" rows="4" required></textarea>
      </label>
      <button type="submit" class="btn btn--primary">{t.contact?.send ?? 'Enviar'}</button>
      <div class="contact-form__feedback" id="contact-form-feedback" style="display:none;"></div>
    </form>
  </div>
</div>
