---
interface Props { kind: 'blocs' | 'napptilius' | 'iusintegra' | 'vaivera' | 'xarop' | 'vueling' }
const { kind } = Astro.props;
---
<div class="viz">
  {kind === 'blocs' && (
    <svg viewBox="0 0 200 150" preserveAspectRatio="xMidYMid slice">
      <rect x="20"  y="20" width="50" height="50"/>
      <rect x="80"  y="20" width="50" height="50" class="fill"/>
      <rect x="140" y="20" width="40" height="50"/>
      <rect x="20"  y="80" width="40" height="50" class="fill"/>
      <rect x="70"  y="80" width="50" height="50"/>
      <rect x="130" y="80" width="50" height="50" class="fill"/>
    </svg>
  )}
  {kind === 'napptilius' && (
    <svg viewBox="0 0 200 150" preserveAspectRatio="xMidYMid slice">
      <rect x="40"  y="35" width="36" height="80" rx="6"/>
      <rect x="82"  y="35" width="36" height="80" rx="6" class="fill"/>
      <rect x="124" y="35" width="36" height="80" rx="6"/>
      <line x1="50"  y1="50" x2="66"  y2="50"/>
      <line x1="50"  y1="58" x2="66"  y2="58"/>
      <line x1="134" y1="50" x2="150" y2="50"/>
      <line x1="134" y1="58" x2="150" y2="58"/>
    </svg>
  )}
  {kind === 'iusintegra' && (
    <svg viewBox="0 0 200 150" preserveAspectRatio="xMidYMid slice">
      <line x1="100" y1="30" x2="100" y2="120"/>
      <line x1="40"  y1="65" x2="160" y2="65"/>
      <path d="M40 65 Q40 95 25 95 Q25 95 25 100 L55 100 Q55 95 55 95 Q40 95 40 65" />
      <path d="M160 65 Q160 95 145 95 Q145 95 145 100 L175 100 Q175 95 175 95 Q160 95 160 65" />
      <rect x="92" y="115" width="16" height="6" class="fill"/>
      <circle cx="100" cy="30" r="4" class="fill"/>
    </svg>
  )}
  {kind === 'vaivera' && (
    <svg viewBox="0 0 200 150" preserveAspectRatio="xMidYMid slice">
      <rect x="25"  y="25" width="70" height="55"/>
      <rect x="105" y="25" width="70" height="35" class="fill"/>
      <rect x="105" y="70" width="35" height="55"/>
      <rect x="150" y="70" width="25" height="55" class="fill"/>
      <rect x="25"  y="90" width="70" height="35"/>
    </svg>
  )}
  {kind === 'xarop' && (
    <svg viewBox="0 0 200 150" preserveAspectRatio="xMidYMid slice">
      <circle cx="30"  cy="75" r="10" class="fill"/>
      <circle cx="58"  cy="75" r="10"/>
      <circle cx="86"  cy="75" r="10" class="fill"/>
      <circle cx="114" cy="75" r="10"/>
      <circle cx="142" cy="75" r="10" class="fill"/>
      <circle cx="170" cy="75" r="10"/>
      <circle cx="100" cy="35" r="6"  class="fill"/>
    </svg>
  )}
  {kind === 'vueling' && (
    <svg viewBox="0 0 200 150" preserveAspectRatio="xMidYMid slice">
      <path d="M0 110 Q50 30 100 90 T200 50"/>
      <path d="M0 130 Q60 60 120 105 T200 80"/>
      <circle cx="180" cy="55"  r="4" class="fill"/>
      <circle cx="20"  cy="115" r="4" class="fill"/>
    </svg>
  )}
</div>
