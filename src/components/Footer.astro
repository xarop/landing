---
import Logo from './Logo.astro';
import type { Translation } from '../i18n/types';
interface Props { t: Translation }
const { t } = Astro.props;
---
<footer>
  <div class="wrap footer__grid">
    <a href="#" class="footer__logo" aria-label="xarop">
      <Logo />
    </a>
    <nav class="footer__nav" aria-label="Footer">
      <a href="mailto:hola@xarop.com">hola@xarop.com</a>
      <a href="https://www.linkedin.com/in/xarop/" target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://github.com/xarop" target="_blank" rel="noopener">GitHub</a>
      <a href="https://web.xarop.com/" target="_blank" rel="noopener">{t.nav.about}</a>
    </nav>
    <div class="footer__meta">{t.footer.rights}</div>
  </div>
</footer>
